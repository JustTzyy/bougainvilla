# ============================================================
# Bougainvilla — Production Environment (Render + Aurora)
# ============================================================
# Copy this file and fill in the values in Render's Dashboard
# under Environment > Environment Variables
# ============================================================

APP_NAME=Bougainvilla
APP_ENV=production
APP_KEY=                          # Run: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://your-app.onrender.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ─── Logging ──────────────────────────────────────────────
# Use stderr so Render captures logs automatically
LOG_CHANNEL=stderr
LOG_LEVEL=warning

# ─── Database (Amazon Aurora MySQL) ──────────────────────
DB_CONNECTION=mysql
DB_HOST=                          # Your Aurora cluster endpoint
DB_PORT=3306
DB_DATABASE=bougainvilla
DB_USERNAME=                      # Your database username
DB_PASSWORD=                      # Your database password

# SSL for Aurora — uses the system CA bundle inside the Docker container
MYSQL_ATTR_SSL_CA=/etc/ssl/certs/ca-certificates.crt

# ─── Session / Cache / Queue ─────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
QUEUE_CONNECTION=database

# ─── Filesystem ──────────────────────────────────────────
# Use S3 if you need persistent file storage (Render disk is ephemeral)
FILESYSTEM_DISK=local
# FILESYSTEM_DISK=s3

# ─── AWS (for S3 file storage, if needed) ────────────────
# Set these in Render's dashboard, NEVER commit real values
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
